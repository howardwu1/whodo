// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String?  @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projects  Project[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  isPrivate   Boolean  @default(true)
  isFavorite  Boolean  @default(false)
  velocity    Int[]    @default([])
  target      Int[]    @default([])
  health      String   @default("green")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stories     Story[]
}

model Story {
  id                  String   @id @default(cuid())
  title               String
  assignee            String   @default("none")
  points              String   @default("unestimated")
  isFinished          Boolean  @default(false)
  isDelivered         Boolean  @default(false)
  isRejected          Boolean  @default(false)
  isAccepted          Boolean  @default(false)
  mentor              String   @default("")
  secondaryAssignee   String   @default("")
  secondaryMentor     String   @default("")
  aTeamSupportTime    String   @default("")
  standupComments     String   @default("")
  sessionAndPMComments String  @default("")
  dateCreated         String   @default("")
  type                String   @default("feature")
  status              String   @default("current_iteration") // current_iteration, icebox, done
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  projectId           String
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
