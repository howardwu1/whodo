# Database connection string (Neon PostgreSQL recommended for Vercel deployment)
# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://user:password@host/database?schema=public"

# Sentry DSN for error tracking (browser-side, must use NEXT_PUBLIC_ prefix)
# Get your DSN from https://sentry.io
NEXT_PUBLIC_SENTRY_DSN="https://example@sentry.io/1234567"

# Node environment
NODE_ENV="development"
